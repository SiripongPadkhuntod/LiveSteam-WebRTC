{
	auto_https disable_redirects
	# Some clients omit SNI when the URL contains an IP address.
	default_sni {$LAN_IP}
}

# LAN HTTPS entry point for the Next.js application and its same-origin BFF.
https://{$LAN_IP}:3443 {
	tls internal
	reverse_proxy {
		dynamic a frontend 3001 {
			refresh 2s
			resolvers 127.0.0.11
			versions ipv4
		}
	}
}

# WebRTC signaling uses WSS through Caddy. Media still travels directly to
# LiveKit over UDP/TCP ports advertised by the LiveKit nodes.
https://{$LAN_IP}:7443 {
	tls internal
	reverse_proxy {
		dynamic a livekit 7880 {
			refresh 2s
			resolvers 127.0.0.11
			versions ipv4
		}
	}
}

https://{$LAN_IP}:7444 {
	tls internal
	reverse_proxy {
		dynamic a d1 7980 {
			refresh 2s
			resolvers 127.0.0.11
			versions ipv4
		}
	}
}

# The public CA certificate is safe to distribute. The CA private key remains
# inside the caddy-data volume. Install root.crt on each LAN test device.
:8081 {
	root * /data/caddy/pki/authorities/local
	header /root.crt Content-Disposition "attachment; filename=caddy-local-root.crt"
	file_server
}
